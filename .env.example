# ============================================
# سلّمها - Environment Variables
# ============================================
# Copy this file to backend/.env and fill in your values

# Application
APP_NAME="سلّمها"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://localhost:8000

# Database
# Development: SQLite (simple, no setup needed)
# Production: PostgreSQL (required for pessimistic locking)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=sallemha
# DB_USERNAME=sallemha
# DB_PASSWORD=secret

# Redis (required for rate limiting & cache)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Sanctum SPA Authentication
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# ============================================
# Production: switch to PostgreSQL + Redis
# DB_CONNECTION=pgsql
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# ============================================
